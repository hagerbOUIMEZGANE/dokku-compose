{
  "name": "dokku-compose",
  "version": "0.3.6",
  "description": "Docker Compose for Dokku — declare your entire server in a single YAML file.",
  "main": "dist/index.js",
  "exports": "./dist/index.js",
  "bin": {
    "dokku-compose": "./dist/index.js"
  },
  "files": [
    "dist/",
    "bin/"
  ],
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "test": "bun test",
    "test:watch": "bun test --watch",
    "build": "tsup src/index.ts --format esm --dts",
    "dev": "bun src/index.ts"
  },
  "keywords": [
    "dokku",
    "deploy",
    "devops",
    "infrastructure",
    "declarative"
  ],
  "author": "Guess",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/guess/dokku-compose.git"
  },
  "homepage": "https://github.com/guess/dokku-compose",
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "execa": "^9.6.1",
    "js-yaml": "^4.1.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.3.3",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
